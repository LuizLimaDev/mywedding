// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model RsvpSubmission {
  id          String   @id @default(cuid())
  confirmedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  guests      Guest[]
}

model Guest {
  id                  String         @id @default(cuid())
  submissionId        String
  fullName            String
  phone               String
  isAdult             Boolean
  invitedBy           InvitedBy
  dietaryRestrictions String?
  createdAt           DateTime       @default(now())
  submission          RsvpSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model RegisteredGuest {
  id        String    @id @default(cuid())
  fullName  String
  phone     String
  kinship   String
  isAdult   Boolean
  invitedBy InvitedBy
  createdAt DateTime  @default(now())
}

enum InvitedBy {
  GROOM
  BRIDE
}
